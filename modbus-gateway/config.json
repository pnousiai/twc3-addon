{
  "name": "Modbus Gateway Add-on",
  "version": "0.1.16",
  "slug": "modbus-gateway",
  "description": "Home Assistant add-on providing a pymodbus 3.x Modbus TCP server with optional serial RTU slave forwarding.",
  "startup": "services",
  "arch": ["amd64",  "aarch64"],
  "host_network": true,
  "homeassistant": "2026.1.0",
  "homeassistant_api": true,
  "uart": true,
  "init": false,
  "options": {
    "modbus_tcp_host": "0.0.0.0",
    "modbus_tcp_port": 503,
    "modbus_unit_id": 1,
    "register_count": 40010,
    "serial_enabled": true,
    "serial_port": "/dev/ttyUSB0",
    "serial_baudrate": 115200,
    "serial_parity": "N",
    "serial_stopbits": 1,
    "serial_bytesize": 8,
    "serial_timeout": 1
  },
  "schema": {
    "modbus_tcp_host": "str",
    "modbus_tcp_port": "int",
    "modbus_unit_id": "int",
    "register_count": "int",
    "serial_enabled": "bool",
    "serial_port": "str",
    "serial_baudrate": "int",
    "serial_parity": "str",
    "serial_stopbits": "int",
    "serial_bytesize": "int",
    "serial_timeout": "int"
  }
}
